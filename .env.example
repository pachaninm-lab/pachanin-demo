# Core
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
ACCESS_TOKEN_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me

# PostgreSQL runtime principals
# Both URLs may target the same PostgreSQL database, but MUST use different roles.
# DATABASE_URL: deal/runtime role, NOSUPERUSER + NOBYPASSRLS + not table owner.
# AUTH_DATABASE_URL: identity role, NOSUPERUSER + BYPASSRLS, with no privileges on public.deals.
# Production startup fails closed when URLs are missing, identical, or role boundaries are unsafe.
DATABASE_URL=
AUTH_DATABASE_URL=
# Optional outside production. Production always enforces the boundary.
DB_PRINCIPAL_BOUNDARY_ENFORCED=false

# =====================================================================
# Security — REQUIRED in production (the API fails closed at startup if
# any of these is unset or shorter than 32 chars; there is NO built-in
# fallback secret). Generate with: openssl rand -hex 32
# =====================================================================
JWT_SECRET=                       # signs/verifies access tokens (>= 32 chars)
AUTH_TOKEN_PEPPER=                # HMAC pepper for refresh/challenge/backup-code hashes
MFA_ENCRYPTION_KEY=               # encrypts TOTP secrets with AES-256-GCM
RATE_LIMIT_KEY_PEPPER=            # independent HMAC pepper for rate-limit subjects (>= 32 chars)
BANK_HMAC_SECRET=                 # verifies Safe-Deals bank callbacks (>= 32 chars)
FGIS_WEBHOOK_SECRET=              # verifies ФГИС Зерно webhooks (>= 32 chars)
EDO_WEBHOOK_SECRET=               # verifies ЭДО (Диадок/СБИС/СберКорус) webhooks (>= 32 chars)

# Reverse proxy trust boundary.
# Production requires explicit direct|cidr. Trust-all CIDRs 0.0.0.0/0 and ::/0 are forbidden.
TRUST_PROXY_MODE=direct
TRUSTED_PROXY_CIDRS=

# Demo accounts (*@demo.ru / demo1234) are seeded ONLY when this is exactly
# "true". Never enable in production or any environment serving real users.
SEED_DEMO_USERS=false

# platform-v7 cabinet gate — leave unset to keep the cabinet locked (fail-closed).
# No hard-coded owner login or default password exists anymore.
PC_CABINET_LOCK_USER=             # cabinet login (email)
PC_CABINET_LOCK_PASSWORD=         # cabinet password
PC_CABINET_SESSION_SECRET=        # optional: dedicated cabinet session signing secret (else JWT_SECRET)

# Runtime / modes
NEXT_PUBLIC_RUN_MODE=demo
PC_STATE_BACKEND=file

# Role-scoped AI assistant
# Development may use the deterministic server-grounded read model. Production
# must select admitted-read-only and provide exact readiness identities; it then
# fails closed rather than substituting a deterministic/static answer.
AI_ASSISTANT_PROVIDER=local
AI_ASSISTANT_RUNTIME_MODE=disabled
# AI_ASSISTANT_RUNTIME_MODE=admitted-read-only
# AI_ASSISTANT_PROVIDER=openai-compatible
# AI_ASSISTANT_BASE_URL=http://127.0.0.1:8080/v1/
# AI_ASSISTANT_MODEL=qwen3-8b-q4-k-m
# AI_ASSISTANT_API_KEY=
# AI_ASSISTANT_READINESS_URL=http://127.0.0.1:8081/readiness
# AI_ASSISTANT_READINESS_TOKEN=
# AI_ASSISTANT_EXPECTED_MODEL_ID=qwen3-8b-q4-k-m
# AI_ASSISTANT_EXPECTED_MODEL_SHA256=<64 hex>
# AI_ASSISTANT_EXPECTED_RUNTIME_ID=llama-server-b9637
# AI_ASSISTANT_EXPECTED_RUNTIME_DIGEST=<64 hex>
# AI_ASSISTANT_EXPECTED_ADMISSION_SHA256=<64 hex>
AI_ASSISTANT_READINESS_TIMEOUT_MS=3000
AI_ASSISTANT_READINESS_MAX_AGE_SECONDS=30
# Comma-separated exact hosts. Non-local hosts must use HTTPS.
AI_ASSISTANT_ALLOWED_HOSTS=127.0.0.1,localhost
RATE_LIMIT_AI_ASSISTANT_CHAT=30
RATE_LIMIT_AI_ASSISTANT_CHAT_WINDOW_SECONDS=60
# Public runtime binding is server-side only. Never expose its token through NEXT_PUBLIC_*.
TAI_PUBLIC_ASSISTANT_RUNTIME_MODE=disabled
# TAI_PUBLIC_ASSISTANT_RUNTIME_MODE=admitted-read-only
# TAI_PUBLIC_ASSISTANT_GATEWAY_URL=http://127.0.0.1:4000/api/public-ai-assistant/stream
# TAI_PUBLIC_ASSISTANT_GATEWAY_TOKEN=
# Synthetic demonstration responses are available only to explicit demo.*
# sessions and are always marked dataMode=synthetic_demo. Real sessions never
# fall back to synthetic facts when the authoritative backend is unavailable.

# Bank / callbacks
BANK_CALLBACK_SECRET=change-me
SBER_CALLBACK_SECRET=change-me
SBER_CREDIT_WIDGET_URL=
SBER_CREDIT_APPLICATION_URL=

# Sber Business Auth
SBER_BUSINESS_AUTH_MODE=sandbox
SBER_BUSINESS_AUTH_URL=
SBER_BUSINESS_TOKEN_URL=
SBER_BUSINESS_PROFILE_URL=
SBER_BUSINESS_CLIENT_ID=
SBER_BUSINESS_CLIENT_SECRET=
SBER_BUSINESS_REDIRECT_URI=
SBER_BUSINESS_SCOPES=
SBER_BUSINESS_STATE_SECRET=change-me

# ---------------------------------------------------------------------------
# External integrations (integration-sdk live layer).
# Per system <NAME>: FGIS_ZERNO, FNS, DIADOK, CRYPTOPRO_DSS, BANK, GPS, FTS,
# RSHN, AML_ROSFINMONITORING, RZD_ETRAN, GIS_EPD, BKI_NBKI, TAKSKOM,
# MARINE_TRAFFIC, SMEV. Default MODE=stub (in-memory mocks). Set MODE=live and
# the required fields to connect. Fail-closed: the API bootstrap calls
# configureIntegrationsFromEnv() at startup, so live/sandbox without the required
# config throws and the process exits instead of silently serving a mock.
# See packages/integration-sdk/INTEGRATION_CONNECT_GUIDE.md.
#
#   <NAME>_MODE            disabled | stub | sandbox | live   (default: stub)
#   <NAME>_BASE_URL        https://api.vendor.example/v1       (required for sandbox/live)
#   <NAME>_AUTH            none | api_key | bearer | oauth2
#   <NAME>_API_KEY_HEADER  X-API-Key                           (for api_key)
#   <NAME>_API_KEY
#   <NAME>_BEARER_TOKEN                                        (for bearer)
#   <NAME>_OAUTH_TOKEN_URL / _OAUTH_CLIENT_ID / _OAUTH_CLIENT_SECRET / _OAUTH_SCOPE  (for oauth2)
#   <NAME>_TIMEOUT_MS      15000
#   <NAME>_MAX_RETRIES     3
#
# Example — bank/escrow via OAuth2 client_credentials:
# BANK_MODE=live
# BANK_BASE_URL=https://api.bank.example/v1
# BANK_AUTH=oauth2
# BANK_OAUTH_TOKEN_URL=https://auth.bank.example/oauth/token
# BANK_OAUTH_CLIENT_ID=
# BANK_OAUTH_CLIENT_SECRET=
# BANK_OAUTH_SCOPE=escrow.write payments.write
FGIS_ZERNO_MODE=stub
BANK_MODE=stub
