# Core
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
ACCESS_TOKEN_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me

# =====================================================================
# Security — REQUIRED in production (the API fails closed at startup if
# any of these is unset or shorter than 32 chars; there is NO built-in
# fallback secret). In non-production a random ephemeral secret is used.
# Generate with: openssl rand -hex 32
# =====================================================================
JWT_SECRET=                       # signs/verifies access tokens (>= 32 chars)
BANK_HMAC_SECRET=                 # verifies Safe-Deals bank callbacks (>= 32 chars)
FGIS_WEBHOOK_SECRET=              # verifies ФГИС Зерно webhooks (>= 32 chars)
EDO_WEBHOOK_SECRET=               # verifies ЭДО (Диадок/СБИС/СберКорус) webhooks (>= 32 chars)

# Demo accounts (*@demo.ru / demo1234) are seeded ONLY when this is exactly
# "true". Never enable in production or any environment serving real users.
SEED_DEMO_USERS=false

# platform-v7 cabinet gate — leave unset to keep the cabinet locked (fail-closed).
# No hard-coded owner login or default password exists anymore.
PC_CABINET_LOCK_USER=             # cabinet login (email)
PC_CABINET_LOCK_PASSWORD=         # cabinet password
PC_CABINET_SESSION_SECRET=        # optional: dedicated cabinet session signing secret (else JWT_SECRET)

# Runtime / modes
NEXT_PUBLIC_RUN_MODE=demo
PC_STATE_BACKEND=file

# Bank / callbacks
BANK_CALLBACK_SECRET=change-me
SBER_CALLBACK_SECRET=change-me
SBER_CREDIT_WIDGET_URL=
SBER_CREDIT_APPLICATION_URL=

# Sber Business Auth
SBER_BUSINESS_AUTH_MODE=sandbox
SBER_BUSINESS_AUTH_URL=
SBER_BUSINESS_TOKEN_URL=
SBER_BUSINESS_PROFILE_URL=
SBER_BUSINESS_CLIENT_ID=
SBER_BUSINESS_CLIENT_SECRET=
SBER_BUSINESS_REDIRECT_URI=
SBER_BUSINESS_SCOPES=
SBER_BUSINESS_STATE_SECRET=change-me
