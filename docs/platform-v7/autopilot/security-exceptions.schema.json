{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prozrachnaya-cena.example/schemas/security-exceptions.schema.json",
  "title": "Industrial Security Exceptions",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "policy", "exceptions"],
  "properties": {
    "schemaVersion": {"const": 1},
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criticalExceptionsAllowed", "maximumExceptionDays"],
      "properties": {
        "criticalExceptionsAllowed": {"const": false},
        "maximumExceptionDays": {"type": "integer", "minimum": 1, "maximum": 90}
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "scanner", "findingId", "severity", "owner", "approvedBy", "ticket", "rationale", "createdAt", "expiresAt"],
        "properties": {
          "id": {"type": "string", "pattern": "^SEC-[0-9]{4}-[0-9]{3,}$"},
          "scanner": {"enum": ["trivy-container", "trivy-filesystem", "trivy-iac", "pnpm-audit"]},
          "findingId": {"type": "string", "minLength": 3},
          "severity": {"const": "HIGH"},
          "owner": {"type": "string", "minLength": 2},
          "approvedBy": {"type": "string", "minLength": 2},
          "ticket": {"type": "string", "pattern": "^#[0-9]+$"},
          "rationale": {"type": "string", "minLength": 20},
          "createdAt": {"type": "string", "format": "date-time"},
          "expiresAt": {"type": "string", "format": "date-time"}
        }
      }
    }
  }
}
