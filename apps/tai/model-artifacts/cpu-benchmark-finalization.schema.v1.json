{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://transparent-price.invalid/schemas/tai.cpu-benchmark-finalization.v1.json",
  "title": "TAI CPU and fallback benchmark finalization v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lifecycle",
    "pending_reason",
    "exact_main",
    "authority_sha256",
    "runtime_report_sha256",
    "quality_report_sha256",
    "qwen_primary",
    "mistral_fallback",
    "storage",
    "finalized_at",
    "qwen_primary_benchmark_status",
    "mistral_fallback_benchmark_status",
    "joint_benchmark_status",
    "model_admission_status",
    "production_operational_status",
    "manifest_sha256"
  ],
  "properties": {
    "schema_version": {"const": "tai.cpu-benchmark-finalization.v1"},
    "lifecycle": {"enum": ["PENDING_EXTERNAL_EVIDENCE", "COMPLETE_CPU_FALLBACK_SLICE"]},
    "pending_reason": {"type": ["string", "null"]},
    "exact_main": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "authority_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "runtime_report_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "quality_report_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "qwen_primary": {"type": ["object", "null"]},
    "mistral_fallback": {"type": ["object", "null"]},
    "storage": {"type": ["object", "null"]},
    "finalized_at": {"type": ["string", "null"], "format": "date-time"},
    "qwen_primary_benchmark_status": {"const": "PENDING_BENCHMARK"},
    "mistral_fallback_benchmark_status": {"enum": ["PENDING_REAL_FINALIZATION_EVIDENCE", "VERIFIED"]},
    "joint_benchmark_status": {"const": "PENDING_BENCHMARK"},
    "model_admission_status": {"const": "PENDING_ADMISSION"},
    "production_operational_status": {"const": "NOT_ATTESTED"},
    "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
