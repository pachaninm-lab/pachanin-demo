# Режим запуска (demo | production)
NEXT_PUBLIC_RUN_MODE=demo

# Яндекс.Метрика — ID счётчика (получить на metrika.yandex.ru)
NEXT_PUBLIC_YM_ID=

# Sentry — DSN проекта (получить на sentry.io или self-hosted GlitchTip)
NEXT_PUBLIC_SENTRY_DSN=

# API бэкенда (опционально, пока используются демо-данные)
NEXT_PUBLIC_API_URL=

# Passwordless demo-вход (detectDemoRole по префиксу email) в проде ОТКЛЮЧЁН по
# умолчанию. Оставьте пустым в production. Включать только осознанно в dev/staging.
PLATFORM_V7_ALLOW_DEMO_LOGIN=

# --- platform-v7 cabinet gate (fail-closed) ---
# Кабинет остаётся заблокированным, пока не заданы логин, пароль и секрет
# подписи. Бэкдор-PIN и hardcoded owner-логин удалены.
JWT_SECRET=                       # секрет подписи cabinet-сессии (>= 32 симв.); openssl rand -hex 32
PC_CABINET_LOCK_USER=             # логин кабинета (email)
PC_CABINET_LOCK_PASSWORD=         # пароль кабинета
PC_CABINET_SESSION_SECRET=        # опц.: отдельный секрет подписи cabinet-сессии (иначе JWT_SECRET)
