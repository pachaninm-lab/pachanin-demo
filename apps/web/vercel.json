{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install --legacy-peer-deps",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "ux-platform-v7-*": true,
      "feat/platform-v7-*": true,
      "audit/platform-v7-*": true,
      "*": false
    }
  },
  "env": {
    "NEXT_PUBLIC_RUN_MODE": "demo"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(self), camera=(), microphone=(), payment=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://mc.yandex.ru https://*.sentry.io; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://mc.yandex.ru https://*.sentry.io; font-src 'self' data:; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
