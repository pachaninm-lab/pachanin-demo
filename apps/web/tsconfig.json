{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/components/platform-v7/GrainExecutionPage": [
        "./components/platform-v7/GrainExecutionPageFixed.tsx"
      ],
      "@pc/design-system-v8": [
        "../../packages/design-system-v8/src/index.tsx"
      ],
      "@pc/design-system-v8/styles.css": [
        "../../packages/design-system-v8/src/styles.css"
      ],
      "@pc/design-tokens": [
        "../../packages/design-tokens/src/index.ts"
      ],
      "@pc/design-tokens/tokens.css": [
        "../../packages/design-tokens/src/tokens.css"
      ],
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "components/platform-v7/GrainExecutionPage.tsx",
    "apps"
  ]
}
