{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/*": ["./node_modules/@types/react/*"],
      "@pc/design-system-v8": ["../../packages/design-system-v8/src/index.ts"]
    }
  },
  "include": [
    "components/crop-platform/CommodityProfileRegistryView.tsx",
    "components/crop-platform/CommodityProfileRegistryClient.tsx",
    "components/crop-platform/commodity-profile-live-adapter.ts",
    "components/crop-platform/css-modules.d.ts",
    "app/platform-v7/commodity-profiles/page.tsx",
    "app/platform-v7/commodity-profiles/[profileId]/page.tsx",
    "app/api/platform-v7/commodity-profiles/[[...path]]/route.ts",
    "app/api/staff/commodity-profile-registry/[[...path]]/route.ts",
    "app/api/staff/commodity-profiles/[profileId]/commands/[actionId]/route.ts",
    "lib/platform-v7/routes.ts",
    "lib/platform-v7/design-system-v8-route-policy.ts",
    "lib/platform-v7/cabinet-access-policy.ts",
    "lib/auth-cookies.ts",
    "lib/server-request-security.ts",
    "stores/usePlatformV7RStore.ts",
    "../../packages/domain-core/src/commodity-profile.ts",
    "../../packages/design-system-v8/src/**/*.ts",
    "../../packages/design-system-v8/src/**/*.tsx"
  ]
}
