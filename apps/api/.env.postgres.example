# Production-shaped env for the API on Postgres (concurrent writers, thousands
# of simultaneous users). Copy to apps/api/.env and adjust secrets.
#
# The Prisma datasource is already postgresql; PG migrations (init + deal_seq)
# live in apps/api/prisma/migrations. Apply with `prisma migrate deploy`.
# See the runbook in docs/platform-v7/RUN_LIVE.md.

# Postgres connection (matches infra/postgres/docker-compose.yml)
DATABASE_URL="postgresql://pachanin:pachanin@localhost:5432/pachanin?schema=public&connection_limit=20&pool_timeout=20"

# Live persistence + repositories (no silent activation; explicit flags)
RUNTIME_PERSISTENCE_MODE=db
PLATFORM_V7_DEAL_REPOSITORY=prisma
PLATFORM_V7_USER_REPOSITORY=prisma

# Auth secrets — REQUIRED. Replace with strong values.
ACCESS_TOKEN_SECRET=replace-me
REFRESH_TOKEN_SECRET=replace-me
JWT_SECRET=replace-me

# API port
PORT=4000
