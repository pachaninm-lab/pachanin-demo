// GrainFlow v3 — production persistence layer (PostgreSQL 16)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Organizations & Users (persistent, replaces in-memory) ────────────────────

model Organization {
  id           String   @id @default(cuid())
  inn          String   @unique
  ogrn         String?
  name         String
  type         String   @default("LEGAL") // LEGAL | INDIVIDUAL | COOPERATIVE
  status       String   @default("PENDING") // PENDING | VERIFIED | SUSPENDED | BLOCKED
  tenantId     String   @default(cuid())
  verifiedAt   DateTime?
  bankDetails  String?  // JSON: bik, account, bankName
  address      String?
  kycStatus    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  amlStatus    String   @default("CLEAR")   // CLEAR | FLAGGED | BLOCKED
  sanctionHit  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        UserOrg[]
  @@index([tenantId])
  @@index([inn])
  @@map("organizations")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?
  passwordHash String
  fullName     String
  status       String   @default("ACTIVE") // ACTIVE | SUSPENDED | BLOCKED
  mfaEnabled   Boolean  @default(false)
  mfaSecret    String?  // TOTP secret (encrypted)
  mfaBackup    String?  // JSON: backup codes hashed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  orgs         UserOrg[]
  ukepCerts    UkepCertificate[]
  @@map("users")
}

model UserOrg {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   // FARMER | BUYER | LOGISTICIAN | DRIVER | LAB | ELEVATOR | ACCOUNTING | EXECUTIVE | SUPPORT_MANAGER | ADMIN | COMPLIANCE_OFFICER | ARBITRATOR
  isDefault      Boolean  @default(false)
  joinedAt       DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("user_orgs")
}

// ── УКЭП Certificates ─────────────────────────────────────────────────────────

model UkepCertificate {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // CRYPTOPRO_DSS | KONTUR | TAXKOM
  externalId   String   // ID в системе провайдера
  thumbprint   String
  subject      String
  issuer       String
  validFrom    DateTime
  validUntil   DateTime
  status       String   @default("VALID") // VALID | REVOKED | EXPIRED
  revokedAt    DateTime?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([thumbprint])
  @@map("ukep_certificates")
}

// ── Deals ─────────────────────────────────────────────────────────────────────

model Deal {
  id            String   @id
  lotId         String?
  sourceLotId   String?  // ссылка на исходный лот-источник (для межрегиональных сделок)
  dealNumber    String?  @unique
  status        String   @default("DRAFT")
  tenantId      String?
  sellerOrgId   String
  buyerOrgId    String
  volumeTons    Float?
  pricePerTon   Float?
  totalRub      Float?
  totalKopecks  Int?
  currency      String   @default("RUB")
  culture       String?
  cropClass     String?
  gost          String?
  region        String?
  incoterms     String?
  fundingChoice String?
  owner         String?
  nextAction    String?
  slaAt         DateTime?
  signedAt      DateTime?
  closedAt      DateTime?
  sagaState     Json?    // current saga step, retry count
  sagaStep      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  meta          String?  // JSON for paymentTerms etc.

  shipments        Shipment[]
  documents        DealDocument[]
  payments         Payment[]
  labSamples       LabSample[]
  dealEvents       DealEvent[]
  acceptanceRecords AcceptanceRecord[]
  bankOperations   BankOperation[]
  runtimeSnapshots DealWorkspaceRuntimeSnapshot[] @relation("RuntimeSnapshotDeal")

  @@index([sellerOrgId])
  @@index([buyerOrgId])
  @@index([status])
  @@index([tenantId])
  @@map("deals")
}

// ── Deal Events (append-only evidence chain) ──────────────────────────────────

model DealEvent {
  id          String   @id @default(cuid())
  dealId      String
  eventType   String
  actorId     String
  actorRole   String
  tenantId    String?
  payload     Json     // structured event data
  hash        String   // SHA-256(id+dealId+eventType+payload+prevHash)
  prevHash    String?  // previous event hash in this deal's chain
  createdAt   DateTime @default(now())

  deal        Deal     @relation(fields: [dealId], references: [id])
  @@index([dealId])
  @@map("deal_events")
}

// ── Shipments ─────────────────────────────────────────────────────────────────

model Shipment {
  id            String   @id
  dealId        String
  status        String   @default("PENDING")
  driverUserId  String?
  driverName    String?
  vehicleNumber String?
  vehicleType   String?  // TRUCK | WAGON | VESSEL
  carrierOrgId  String?
  carrierName   String?
  routeFrom     String?
  routeTo       String?
  etaHours      Float?
  loadedTons    Float?
  pinVerified   Boolean  @default(false)
  nextAction    String?
  blockers      String?  // JSON array
  geoLat        Float?
  geoLng        Float?
  lastGeoAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deal          Deal       @relation(fields: [dealId], references: [id])
  checkpoints   Checkpoint[]

  @@index([dealId])
  @@index([driverUserId])
  @@index([status])
  @@map("shipments")
}

model Checkpoint {
  id          String   @id @default(cuid())
  shipmentId  String
  type        String
  completedAt DateTime?
  lat         Float?
  lng         Float?
  note        String?
  photoUrl    String?
  actorId     String?

  shipment    Shipment @relation(fields: [shipmentId], references: [id])
  @@index([shipmentId])
  @@map("checkpoints")
}

// ── Documents ─────────────────────────────────────────────────────────────────

model DealDocument {
  id               String   @id
  dealId           String
  type             String
  status           String   @default("DRAFT")
  name             String
  mimeType         String?
  s3Key            String?
  sizeBytes        Int?
  hash             String?  // SHA-256 of file content
  uploadedAt       DateTime @default(now())
  uploadedByUserId String?
  signedAt         DateTime?
  signatories      String?  // JSON: [{userId, role, signedAt, thumbprint}]
  bankRequired     Boolean  @default(false)
  releaseRequired  Boolean  @default(false)
  bankAcceptance   String   @default("PENDING")
  edoStatus        String?  // SENT | DELIVERED | SIGNED | REJECTED
  edoExternalId    String?  // ID в системе ЭДО
  version          Int      @default(1)
  isImmutable      Boolean  @default(false) // true after signing

  deal             Deal     @relation(fields: [dealId], references: [id])
  @@index([dealId])
  @@index([type])
  @@map("deal_documents")
}

// ── Payments & Ledger ─────────────────────────────────────────────────────────

model Payment {
  id              String   @id @default(cuid())
  dealId          String
  status          String   @default("PENDING") // PENDING | RESERVED | HELD | RELEASED | REFUNDED | FAILED
  amountRub       Float?   // deprecated: use amountKopecks
  amountKopecks   Int?
  reservedAt      DateTime?
  releasedAt      DateTime?
  holdAmountKopecks Int?
  refundedKopecks Int?
  commissionKopecks Int?
  callbackState   String   @default("NONE")
  bankRef         String?
  escrowAccount   String?
  idempotencyKey  String?  @unique
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  deal            Deal     @relation(fields: [dealId], references: [id])
  @@index([dealId])
  @@map("payments")
}

model LedgerEntry {
  id                String   @id @default(cuid())
  dealId            String?
  entryType         String   // RESERVE | HOLD | RELEASE | REFUND | COMMISSION | PLATFORM_FEE | PENALTY
  debitAccount      String   // org_id or system account
  creditAccount     String
  amountKopecks     Int      // always positive
  currency          String   @default("RUB")
  reference         String?  // payment reference / bank ref
  idempotencyKey    String   @unique
  description       String?
  createdAt         DateTime @default(now())
  createdByUserId   String?

  @@index([dealId])
  @@index([debitAccount])
  @@index([creditAccount])
  @@map("ledger_entries")
}

// ── Lab Samples ───────────────────────────────────────────────────────────────

model LabSample {
  id              String   @id
  dealId          String
  shipmentId      String?
  acceptanceId    String?  // ссылка на AcceptanceRecord
  status          String   @default("PENDING") // PENDING | COLLECTED | TESTING | DONE | REJECTED
  culture         String?
  protocol        String?
  gost            String?
  labId           String?
  labName         String?
  collectedAt     DateTime?
  finalizedAt     DateTime?
  moneyDeltaRub   Float?
  moneyDeltaKopecks Int?
  certificateDocId String?
  version         Int      @default(1)
  createdAt       DateTime @default(now())

  tests           LabTest[]
  deal            Deal      @relation(fields: [dealId], references: [id])
  @@index([dealId])
  @@map("lab_samples")
}

model LabTest {
  id         String   @id @default(cuid())
  sampleId   String
  parameter  String   // moisture | protein | gluten | impurity | fallNumber | idi | etc.
  value      Float
  unit       String?
  normMin    Float?
  normMax    Float?
  passed     Boolean  @default(true)
  gradeDelta Float?   // price adjustment coefficient
  recordedAt DateTime @default(now())

  sample     LabSample @relation(fields: [sampleId], references: [id])
  @@index([sampleId])
  @@map("lab_tests")
}

// ── Outbox ────────────────────────────────────────────────────────────────────

model OutboxEntry {
  id                    String   @id @default(cuid())
  type                  String
  dealId                String?
  payload               Json
  status                String   @default("PENDING") // PENDING | SENT | CONFIRMED | FAILED | DEAD
  idempotencyKey        String?  @unique
  maxRetries            Int      @default(5)
  retryCount            Int      @default(0)
  nextRetryAt           DateTime @default(now())
  lastError             String?
  correlationId         String?
  auditId               String?
  runtimeSnapshotId     String?
  runtimeIdempotencyKey String?
  createdAt             DateTime @default(now())
  sentAt                DateTime?
  confirmedAt           DateTime?
  failedAt              DateTime?

  runtimeSnapshot       DealWorkspaceRuntimeSnapshot? @relation("RuntimeSnapshotOutbox")

  @@index([status, nextRetryAt])
  @@index([dealId])
  @@index([runtimeSnapshotId], map: "outbox_entries_runtime_snapshot_idx")
  @@index([correlationId], map: "outbox_entries_runtime_correlation_idx")
  @@map("outbox_entries")
}

// ── Disputes ──────────────────────────────────────────────────────────────────

model Dispute {
  id               String   @id @default(cuid())
  dealId           String
  shipmentId       String?
  type             String
  status           String   @default("OPEN") // OPEN | ARBITRATION | RESOLVED | CANCELLED
  description      String
  initiatorOrgId   String
  respondentOrgId  String?
  claimAmountRub   Float?
  claimAmountKopecks Int?
  severity         String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  slaMinutes       Int?
  arbitratorId     String?
  arbitratorNotes  String?
  outcome          String?  // BUYER_WINS | SELLER_WINS | SPLIT | CANCELLED
  outcomeSplitPct  Int?     // % of claim returned to buyer (0–100)
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  moneyHold        DisputeMoneyHold?
  evidence         DisputeEvidence[]
  auditEvents      AuditEvent[]

  @@index([dealId])
  @@index([status])
  @@index([arbitratorId])
  @@map("disputes")
}

model DisputeMoneyHold {
  id              String   @id @default(cuid())
  disputeId       String   @unique
  amountRub       Float?
  amountKopecks   Int?
  reason          String
  heldAt          DateTime @default(now())
  releasedAt      DateTime?
  releaseReason   String?

  dispute         Dispute  @relation(fields: [disputeId], references: [id])
  @@map("dispute_money_holds")
}

model DisputeEvidence {
  id          String   @id @default(cuid())
  disputeId   String
  fileId      String?
  type        String   // PHOTO | DOCUMENT | LAB_RESULT | GPS_TRACK | STATEMENT | OTHER
  description String
  trusted     Boolean  @default(false)
  submittedBy String
  submittedAt DateTime @default(now())
  hash        String?
  prevHash    String?

  dispute     Dispute  @relation(fields: [disputeId], references: [id])
  @@index([disputeId])
  @@map("dispute_evidence")
}

// ── Evidence Pack ─────────────────────────────────────────────────────────────

model EvidenceFile {
  id          String   @id @default(cuid())
  dealId      String
  shipmentId  String?
  disputeId   String?
  type        String
  filename    String
  mimeType    String
  sizeBytes   Int
  hash        String   // SHA-256 of content
  prevHash    String?  // previous evidence hash for chain
  s3Key       String?
  uploadedBy  String
  uploadedAt  DateTime @default(now())
  metadata    Json?    // geoLat, geoLng, deviceId, etc.

  @@index([dealId])
  @@index([disputeId])
  @@map("evidence_files")
}

// ── Audit Events (append-only, hash chain) ────────────────────────────────────

model AuditEvent {
  id                    String   @id @default(cuid())
  action                String
  actorUserId           String
  actorRole             String
  tenantId              String?
  orgId                 String?
  dealId                String?
  disputeId             String?
  objectType            String?
  objectId              String?
  beforeState           Json?    // snapshot before change
  afterState            Json?    // snapshot after change
  outcome               String
  reason                String?
  metadata              Json?    // ip, userAgent, sessionId
  correlationId         String?
  runtimeSnapshotId     String?
  runtimeIdempotencyKey String?
  hash                  String   @default("") // SHA-256(all fields + prevHash)
  prevHash              String?
  createdAt             DateTime @default(now())

  dispute               Dispute? @relation(fields: [disputeId], references: [id])
  runtimeSnapshot       DealWorkspaceRuntimeSnapshot? @relation("RuntimeSnapshotAudit")

  @@index([dealId])
  @@index([actorUserId])
  @@index([action])
  @@index([tenantId])
  @@index([runtimeSnapshotId], map: "audit_events_runtime_snapshot_idx")
  @@index([correlationId], map: "audit_events_runtime_correlation_idx")
  @@map("audit_events")
}

// ── Integration Events (log of all adapter calls) ─────────────────────────────

model IntegrationEvent {
  id              String   @id @default(cuid())
  adapterName     String   // FGIS_ZERNO | FNS | DIADOK | CRYPTOPRO | BANK | GPS | FTS
  direction       String   // INBOUND | OUTBOUND
  eventType       String
  externalId      String?
  dealId          String?
  requestPayload  Json?
  responsePayload Json?
  status          String   // SUCCESS | ERROR | PENDING | TIMEOUT
  errorMessage    String?
  httpStatus      Int?
  durationMs      Int?
  idempotencyKey  String?
  createdAt       DateTime @default(now())

  @@index([adapterName, status])
  @@index([dealId])
  @@index([externalId])
  @@map("integration_events")
}

// ── Webhook Security ──────────────────────────────────────────────────────────

model WebhookIdempotency {
  id           String   @id @default(cuid())
  eventId      String   @unique
  adapterName  String
  processedAt  DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
  @@map("webhook_idempotency")
}

// ── KYC / AML Queue ───────────────────────────────────────────────────────────

model KycTask {
  id             String   @id @default(cuid())
  organizationId String
  type           String   // INITIAL | PERIODIC | TRIGGERED
  status         String   @default("PENDING") // PENDING | IN_REVIEW | APPROVED | REJECTED
  assignedTo     String?  // compliance officer userId
  notes          String?
  fnsResponse    Json?
  sanctionResult Json?
  amlResult      Json?
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([organizationId])
  @@map("kyc_tasks")
}

// ── Stored Files (Storage module — S3 presigned URL) ──────────────────────────

model StoredFile {
  id               String   @id @default(cuid())
  dealId           String?
  s3Key            String
  bucket           String   @default("grainflow-documents")
  filename         String
  mimeType         String
  sizeBytes        BigInt?
  sha256           String?
  status           String   @default("PENDING_UPLOAD") // PENDING_UPLOAD | UPLOADED | CONFIRMED | DELETED
  uploadedByUserId String?
  confirmedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([dealId])
  @@index([s3Key])
  @@map("stored_files")
}

// ── Factoring Applications ────────────────────────────────────────────────────

model FactoringApplication {
  id               String   @id @default(cuid())
  organizationId   String
  dealId           String?
  status           String   @default("PENDING") // PENDING | APPROVED | REJECTED | ACTIVE | OVERDUE | REPAID
  requestedKopecks BigInt?
  approvedKopecks  BigInt?
  factorName       String?
  dueDate          DateTime?
  repaidAt         DateTime?
  contractDocId    String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([dueDate])
  @@map("factoring_applications")
}

// ── Geofences ─────────────────────────────────────────────────────────────────

model Geofence {
  id            String   @id @default(cuid())
  dealId        String?
  name          String
  type          String   @default("CIRCLE") // CIRCLE | POLYGON
  centerLat     Float?
  centerLng     Float?
  radiusMeters  Float?
  polygon       Json?    // [{lat, lng}]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([dealId])
  @@map("geofences")
}

// ── Acceptance Records (акт приёма) ──────────────────────────────────────────

model AcceptanceRecord {
  id                String   @id @default(cuid())
  dealId            String
  shipmentId        String?
  status            String   @default("PENDING") // PENDING | ACCEPTED | PARTIAL | REJECTED
  weightActualTons  Float?
  volumeActualTons  Float?
  qualityStatus     String   @default("PENDING") // PENDING | PASSED | FAILED | PARTIAL
  gost              String?
  actDocId          String?  // ID документа — акт приёма
  actSignedAt       DateTime?
  actorId           String   // elevator/lab operator userId
  notes             String?
  moneyAdjustKopecks Int?    // корректировка суммы по результату приёма
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deal              Deal     @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@index([shipmentId])
  @@map("acceptance_records")
}

// ── Bank Operations ───────────────────────────────────────────────────────────

model BankOperation {
  id                String   @id @default(cuid())
  dealId            String
  type              String   // RESERVE | HOLD | RELEASE | REFUND | COMMISSION | FACTORING_DISBURSEMENT
  status            String   @default("PENDING") // PENDING | PROCESSING | DONE | FAILED | REVERSED
  amountKopecks     BigInt
  currency          String   @default("RUB")
  debitAccount      String
  creditAccount     String
  bankRef           String?  // внешний ID операции в банке
  bankName          String?
  idempotencyKey    String   @unique
  requestPayload    Json?
  responsePayload   Json?
  initiatorUserId   String?
  confirmedAt       DateTime?
  failureReason     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deal              Deal     @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@index([status])
  @@index([type])
  @@map("bank_operations")
}

// ── Accounts (for money invariants) ───────────────────────────────────────────

model Account {
  id              String   @id
  orgId           String?
  type            String   @default("ORG") // ORG | ESCROW | DISPUTE_HOLD | PLATFORM
  balanceKopecks  BigInt   @default(0)
  reservedKopecks BigInt   @default(0)
  currency        String   @default("RUB")
  updatedAt       DateTime @updatedAt

  @@index([orgId])
  @@map("accounts")
}

// ── Deal Workspace Runtime Persistence ────────────────────────────────────────

model DealWorkspaceRuntimeSnapshot {
  id                   String   @id @default(cuid())
  runtimeSnapshotId    String
  idempotencyKey       String
  dealId               String
  intentId             String
  state                String
  snapshotState        String
  statusLabel          String
  runtimeStoreRecordId String
  runtimeStoreVersion  String
  actorId              String
  actorRole            String
  correlationId        String
  auditId              String
  contractHash         String
  payload              Json
  outboxEntryId        String?
  auditEventId         String?
  version              Int      @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  deal                 Deal      @relation("RuntimeSnapshotDeal", fields: [dealId], references: [id], onDelete: Restrict, map: "dw_runtime_snapshots_deal_fkey")
  outboxEntry          OutboxEntry? @relation("RuntimeSnapshotOutbox", fields: [outboxEntryId], references: [id], onDelete: Restrict, map: "dw_runtime_snapshots_outbox_fkey")
  auditEvent           AuditEvent? @relation("RuntimeSnapshotAudit", fields: [auditEventId], references: [id], onDelete: Restrict, map: "dw_runtime_snapshots_audit_fkey")
  attempts             DealWorkspaceRuntimeTransactionAttempt[]

  @@unique([runtimeSnapshotId], map: "dw_runtime_snapshots_runtime_snapshot_id_key")
  @@unique([idempotencyKey], map: "dw_runtime_snapshots_idempotency_key_key")
  @@unique([outboxEntryId], map: "dw_runtime_snapshots_outbox_entry_id_key")
  @@unique([auditEventId], map: "dw_runtime_snapshots_audit_event_id_key")
  @@index([dealId, createdAt], map: "dw_runtime_snapshots_deal_created_idx")
  @@index([intentId, state], map: "dw_runtime_snapshots_intent_state_idx")
  @@index([correlationId], map: "dw_runtime_snapshots_correlation_idx")
  @@index([state, updatedAt], map: "dw_runtime_snapshots_state_updated_idx")
  @@map("deal_workspace_runtime_snapshots")
}

model DealWorkspaceRuntimeTransactionAttempt {
  id             String   @id @default(cuid())
  transactionId  String
  snapshotId     String
  idempotencyKey String
  correlationId  String
  auditId        String
  stage          String
  outcome        String?
  failureCode    String?
  failureReason  String?
  isReplay       Boolean  @default(false)
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  metadata       Json?

  snapshot       DealWorkspaceRuntimeSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict, map: "dw_runtime_attempts_snapshot_fkey")

  @@unique([transactionId], map: "dw_runtime_attempts_transaction_id_key")
  @@index([snapshotId, startedAt], map: "dw_runtime_attempts_snapshot_started_idx")
  @@index([stage, startedAt], map: "dw_runtime_attempts_stage_started_idx")
  @@index([idempotencyKey], map: "dw_runtime_attempts_idempotency_idx")
  @@index([correlationId], map: "dw_runtime_attempts_correlation_idx")
  @@map("deal_workspace_runtime_transaction_attempts")
}
