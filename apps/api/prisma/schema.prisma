// GrainFlow v3 — production persistence layer (PostgreSQL 16)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Organizations & Users ─────────────────────────────────────────────────────

model Organization {
  id               String   @id @default(cuid())
  inn              String   @unique
  ogrn             String?
  name             String
  type             String   @default("LEGAL")
  status           String   @default("PENDING")
  tenantId         String   @default(cuid())
  verifiedAt       DateTime?
  bankDetails      String?
  address          String?
  kycStatus        String   @default("PENDING")
  amlStatus        String   @default("CLEAR")
  sanctionHit      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users                             UserOrg[]
  dealParticipants                  DealParticipant[]
  regulatoryIntegrationInboxEntries RegulatoryIntegrationInboxEntry[]

  @@index([tenantId])
  @@index([inn])
  @@map("organizations")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  phone            String?
  passwordHash     String
  fullName         String
  status           String   @default("ACTIVE")
  mfaEnabled       Boolean  @default(false)
  mfaSecret        String?
  mfaBackup        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  orgs             UserOrg[]
  ukepCerts        UkepCertificate[]
  dealParticipants DealParticipant[]

  @@map("users")
}

model UserOrg {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String
  isDefault      Boolean  @default(false)
  joinedAt       DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("user_orgs")
}

model UkepCertificate {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  externalId   String
  thumbprint   String
  subject      String
  issuer       String
  validFrom    DateTime
  validUntil   DateTime
  status       String   @default("VALID")
  revokedAt    DateTime?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([thumbprint])
  @@map("ukep_certificates")
}

// ── Deals ────────────────────────────────────────────────────────────────────

model Deal {
  id                String   @id
  lotId             String?
  sourceLotId       String?
  dealNumber        String?  @unique
  status            String   @default("DRAFT")
  tenantId          String?
  sellerOrgId       String
  buyerOrgId        String
  volumeTons        Float?
  pricePerTon       Float?
  totalRub          Float?
  totalKopecks      BigInt?
  pricePerTonDec    Decimal? @db.Decimal(20, 6)
  volumeTonsDec     Decimal? @db.Decimal(20, 6)
  version           BigInt   @default(0)
  currency          String   @default("RUB")
  culture           String?
  cropClass         String?
  gost              String?
  region            String?
  incoterms         String?
  fundingChoice     String?
  owner             String?
  nextAction        String?
  slaAt             DateTime?
  signedAt          DateTime?
  closedAt          DateTime?
  sagaState         Json?
  sagaStep          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  meta              String?

  participants      DealParticipant[]
  shipments         Shipment[]
  documents         DealDocument[]
  payments          Payment[]
  labSamples        LabSample[]
  dealEvents        DealEvent[]
  acceptanceRecords AcceptanceRecord[]
  bankOperations    BankOperation[]
  runtimeSnapshots  DealWorkspaceRuntimeSnapshot[] @relation("RuntimeSnapshotDeal")

  @@index([sellerOrgId])
  @@index([buyerOrgId])
  @@index([status])
  @@index([tenantId])
  @@map("deals")
}

model DealParticipant {
  id               String   @id @default(cuid())
  dealId           String
  tenantId         String
  organizationId   String
  userId           String
  role             String
  accessLevel      String   @default("WORK") // READ | WORK | APPROVE
  status           String   @default("ACTIVE") // ACTIVE | SUSPENDED | REVOKED
  assignedByUserId String?
  assignedAt       DateTime @default(now())
  revokedAt        DateTime?

  deal             Deal         @relation(fields: [dealId], references: [id], onDelete: Restrict)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user             User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([dealId, userId, role])
  @@index([dealId, status])
  @@index([tenantId, organizationId])
  @@index([userId, status])
  @@index([role, status])
  @@map("deal_participants")
}

model DealEvent {
  id          String   @id @default(cuid())
  dealId      String
  eventType   String
  actorId     String
  actorRole   String
  tenantId    String?
  payload     Json
  hash        String
  prevHash    String?
  createdAt   DateTime @default(now())

  deal        Deal     @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@index([dealId, createdAt], map: "deal_events_deal_created_idx")
  @@map("deal_events")
}

// ── Shipments ─────────────────────────────────────────────────────────────────

model Shipment {
  id                    String   @id
  dealId                String
  tenantId              String   @default(dbgenerated("current_setting('app.current_tenant_id'::text, true)"))
  status                String   @default("PENDING")
  driverUserId          String?
  driverName            String?
  vehicleNumber         String?
  vehicleType           String?
  carrierOrgId          String?
  carrierName           String?
  routeFrom             String?
  routeTo               String?
  etaHours              Float?
  loadedTons            Float?
  pinVerified           Boolean  @default(false)
  driverPinHash         String?
  pinVerifiedAt         DateTime?
  pinVerifiedByUserId   String?
  pinFailedAttempts     Int      @default(0)
  pinLockedUntil        DateTime?
  version               BigInt   @default(0)
  nextAction            String?
  blockers              String?
  geoLat                Float?
  geoLng                Float?
  lastGeoAt             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  deal                  Deal               @relation(fields: [dealId], references: [id])
  checkpoints           Checkpoint[]
  gpsPoints             ShipmentGpsPoint[]

  @@index([dealId])
  @@index([tenantId])
  @@index([driverUserId])
  @@index([carrierOrgId])
  @@index([status])
  @@map("s