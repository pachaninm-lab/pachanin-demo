{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "brand": {
      "50": { "$type": "color", "$value": "#eef8f3" },
      "100": { "$type": "color", "$value": "#d8eee3" },
      "600": { "$type": "color", "$value": "#176b4a" },
      "700": { "$type": "color", "$value": "#11563c" },
      "800": { "$type": "color", "$value": "#0b432f" }
    },
    "neutral": {
      "0": { "$type": "color", "$value": "#ffffff" },
      "50": { "$type": "color", "$value": "#f7f9f8" },
      "100": { "$type": "color", "$value": "#edf1ef" },
      "300": { "$type": "color", "$value": "#c9d2cd" },
      "600": { "$type": "color", "$value": "#52615a" },
      "800": { "$type": "color", "$value": "#233129" },
      "950": { "$type": "color", "$value": "#101814" }
    },
    "status": {
      "success": { "$type": "color", "$value": "#16794f" },
      "warning": { "$type": "color", "$value": "#9a5b00" },
      "danger": { "$type": "color", "$value": "#b42318" },
      "info": { "$type": "color", "$value": "#175cd3" }
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": { "value": 0, "unit": "px" } },
    "1": { "$type": "dimension", "$value": { "value": 4, "unit": "px" } },
    "2": { "$type": "dimension", "$value": { "value": 8, "unit": "px" } },
    "3": { "$type": "dimension", "$value": { "value": 12, "unit": "px" } },
    "4": { "$type": "dimension", "$value": { "value": 16, "unit": "px" } },
    "5": { "$type": "dimension", "$value": { "value": 20, "unit": "px" } },
    "6": { "$type": "dimension", "$value": { "value": 24, "unit": "px" } },
    "8": { "$type": "dimension", "$value": { "value": 32, "unit": "px" } },
    "10": { "$type": "dimension", "$value": { "value": 40, "unit": "px" } },
    "12": { "$type": "dimension", "$value": { "value": 48, "unit": "px" } }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": { "value": 8, "unit": "px" } },
    "md": { "$type": "dimension", "$value": { "value": 12, "unit": "px" } },
    "lg": { "$type": "dimension", "$value": { "value": 16, "unit": "px" } },
    "xl": { "$type": "dimension", "$value": { "value": 20, "unit": "px" } },
    "pill": { "$type": "dimension", "$value": { "value": 999, "unit": "px" } }
  },
  "size": {
    "control": {
      "compact": { "$type": "dimension", "$value": { "value": 40, "unit": "px" } },
      "comfortable": { "$type": "dimension", "$value": { "value": 44, "unit": "px" } },
      "field": { "$type": "dimension", "$value": { "value": 48, "unit": "px" } }
    },
    "content": {
      "max": { "$type": "dimension", "$value": { "value": 1440, "unit": "px" } }
    }
  },
  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": { "value": 120, "unit": "ms" } },
      "normal": { "$type": "duration", "$value": { "value": 180, "unit": "ms" } }
    }
  }
}
