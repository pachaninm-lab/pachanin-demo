# Copy to .env and fill in. NEVER commit the filled .env.
# Passwords: use long random values (letters + digits, 24+ chars).

# --- where to publish the site ---
# Bare IP: prefix http:// so Caddy serves plain HTTP (no cert exists for an IP).
# Domain: use the bare hostname (e.g. cabinet.example.ru) for automatic HTTPS.
SITE_ADDRESS=http://195.19.12.120

# --- container images (GitHub Container Registry) ---
IMAGE_PREFIX=ghcr.io/pachaninm-lab/grainflow

# --- database principals (the platform enforces a three-role boundary) ---
# DDL_PASSWORD     -> grainflow_ddl : migration/DDL owner (owns tables)
# APP_PASSWORD     -> app_deal_api  : deal runtime  (NOINHERIT, NOBYPASSRLS)
# AUTH_PASSWORD    -> app_service   : auth runtime  (NOINHERIT, BYPASSRLS)
# STORAGE_PASSWORD -> app_storage   : evidence finalization (SELECT+UPDATE docs)
DDL_PASSWORD=change-me-ddl-owner
APP_PASSWORD=change-me-deal-runtime
AUTH_PASSWORD=change-me-auth-runtime
STORAGE_PASSWORD=change-me-storage-runtime
REDIS_PASSWORD=change-me-redis
PG_SHARED_BUFFERS=1GB

# --- application secrets ---
JWT_SECRET=change-me-to-a-64-char-random-secret
RATE_LIMIT_KEY_PEPPER=change-me-to-a-32-char-random-secret

# Bank settlement HMAC (RSHB). Replace with the real partner keys at integration.
BANK_HMAC_SECRET=change-me-bank-hmac-secret-min-32-chars
BANK_PARTNER_ID=safe-deals
BANK_HMAC_KEY_ID=primary

# Inbound webhook signing secrets (min 32 chars) — required in production.
FGIS_WEBHOOK_SECRET=change-me-fgis-webhook-secret-min-32-chars
EDO_WEBHOOK_SECRET=change-me-edo-webhook-secret-min-32-chars

# Test/mutation flags MUST stay disabled in production (fail-closed startup).
AUTH_TEST_ACCOUNTS_ENABLED=0
ALLOW_RUNTIME_MUTATION=0

# Object storage (MinIO, S3-compatible) — documents/evidence.
MINIO_ROOT_USER=grainflow
MINIO_ROOT_PASSWORD=change-me-minio-password
