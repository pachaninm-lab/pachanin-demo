# Edge reverse proxy with automatic HTTPS.
# SITE_ADDRESS is a domain (→ automatic Let's Encrypt certificate) or, before a
# domain exists, an http://<ip> address (→ plain HTTP; an IP cannot be issued a
# certificate, so the http:// scheme keeps Caddy from redirecting to a TLS
# listener it cannot provision).
#
# Routing model: the Next.js web app is the single browser origin. It owns most
# /api/* routes (auth/session, sim, staff, platform-v7, runtime-*, and the
# /api/proxy/* bridge) and reaches the NestJS backend internally. Only the
# operational probes and the few backend-direct namespaces go straight to the API.
{$SITE_ADDRESS} {
	# Harden every response (HSTS is meaningful once served over HTTPS).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	# Drop common vulnerability-scanner and secret-file probes at the edge
	# (e.g. .env, .git, .vscode, wp-admin) before they reach the app.
	@probes path *.env /.git* /.svn* /.hg* /.aws* /.ssh* /.vscode* /.idea* *.sql *.bak *.old *.swp /sftp.json /wp-login.php /wp-admin* /wp-content* /xmlrpc.php /phpmyadmin* /pma* /vendor/* /actuator* /cgi-bin/*
	handle @probes {
		abort
	}

	# Operational probes → NestJS backend.
	handle /health {
		reverse_proxy api:3001
	}
	handle /ready {
		reverse_proxy api:3001
	}

	# Backend-direct API namespaces (no web-native handler).
	handle /api/deals* {
		reverse_proxy api:3001
	}
	handle /api/fgis* {
		reverse_proxy api:3001
	}

	# Everything else — pages and web-owned /api/* routes — goes to Next.js,
	# which proxies to the backend internally where needed.
	handle {
		reverse_proxy web:3000
	}
}
