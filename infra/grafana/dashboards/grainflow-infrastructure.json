{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus"}],
  "title": "GrainFlow — Infrastructure",
  "uid": "grainflow-infra",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "API CPU Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "rate(process_cpu_seconds_total{job=\"grainflow-api\"}[1m]) * 100",
        "legendFormat": "CPU %"
      }]
    },
    {
      "id": 2,
      "title": "API Memory (MB)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "process_resident_memory_bytes{job=\"grainflow-api\"} / 1024 / 1024",
        "legendFormat": "RSS MB"
      }]
    },
    {
      "id": 3,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "kafka_consumer_group_lag{group=~\"grainflow.*\"}",
        "legendFormat": "{{topic}} {{group}}"
      }]
    },
    {
      "id": 4,
      "title": "PostgreSQL Connections",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "pg_stat_activity_count{datname=\"grainflow\"}",
        "legendFormat": "Active connections"
      }]
    },
    {
      "id": 5,
      "title": "Redis Memory Used",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 16},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "redis_memory_used_bytes / 1024 / 1024",
        "legendFormat": "MB used"
      }]
    },
    {
      "id": 6,
      "title": "Elasticsearch Cluster Health",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 16},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "elasticsearch_cluster_health_status{color=\"green\"}",
        "legendFormat": "Green shards"
      }]
    },
    {
      "id": 7,
      "title": "HTTP P99 Latency (All services)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(grainflow_http_request_duration_seconds_bucket[5m])) by (le, route)) * 1000",
        "legendFormat": "p99 {{route}} ms"
      }]
    }
  ]
}
