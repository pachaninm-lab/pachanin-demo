{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus"}],
  "title": "GrainFlow — ML Service Metrics",
  "uid": "grainflow-ml",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "ML Requests per Second",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "sum(rate(grainflow_http_requests_total{route=~\"/api/ml/.*\"}[1m])) by (route)",
        "legendFormat": "{{route}}"
      }]
    },
    {
      "id": 2,
      "title": "ML P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(grainflow_http_request_duration_seconds_bucket{route=~\"/api/ml/.*\"}[5m])) by (le, route)) * 1000",
        "legendFormat": "p95 {{route}}"
      }]
    },
    {
      "id": 3,
      "title": "Fraud Score Distribution",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "datasource": {"type": "prometheus"},
      "options": {"colorMode": "background"},
      "targets": [{
        "expr": "sum(rate(grainflow_http_requests_total{route=\"/api/ml/fraud/check\",status_code=\"200\"}[5m])) * 60",
        "legendFormat": "Fraud checks/min"
      }]
    },
    {
      "id": 4,
      "title": "Price Predictions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "sum(rate(grainflow_http_requests_total{route=\"/api/ml/price/predict\",status_code=\"200\"}[5m])) * 60",
        "legendFormat": "Predictions/min"
      }]
    },
    {
      "id": 5,
      "title": "Counterparty Scorings",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "datasource": {"type": "prometheus"},
      "targets": [{
        "expr": "sum(rate(grainflow_http_requests_total{route=\"/api/ml/scoring/score\",status_code=\"200\"}[5m])) * 60",
        "legendFormat": "Scorings/min"
      }]
    },
    {
      "id": 6,
      "title": "ML Error Rate %",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "green"}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}},
      "targets": [{
        "expr": "sum(rate(grainflow_http_requests_total{route=~\"/api/ml/.*\",status_code=~\"5..\"}[5m])) / sum(rate(grainflow_http_requests_total{route=~\"/api/ml/.*\"}[5m])) * 100",
        "legendFormat": "Error %"
      }]
    }
  ]
}
